<file path="resources/js/Pages/Todos/Index.tsx">
import { FormEvent, useMemo, useState } from 'react';
import { Head } from '@inertiajs/react';
import { useMutation, useQuery, useQueryClient } from '@tanstack/react-query';
import { deleteJson, fetchJson, patchJson, postJson } from '@/lib/api';
import type { ApiResponse, Todo, TodoListResponse, TodoResponse } from '@/types';

type TodosIndexProps = {
    title?: string;
};

export default function TodosIndex({ title }: TodosIndexProps) {
    const [newTitle, setNewTitle] = useState('');
    const queryClient = useQueryClient();

    const {
        data,
        isLoading,
        isError,
        error,
        isFetching,
    } = useQuery<TodoListResponse, Error>({
        queryKey: ['todos'],
        queryFn: () => fetchJson<TodoListResponse>('/api/todos'),
    });

    const createTodo = useMutation<TodoResponse, Error, string>({
        mutationFn: (title) => postJson<TodoResponse>('/api/todos', { title }),
        onSuccess: () => {
            setNewTitle('');
            queryClient.invalidateQueries({ queryKey: ['todos'] });
        },
    });

    const toggleTodo = useMutation<TodoResponse, Error, Todo>({
        mutationFn: (todo) =>
            patchJson<TodoResponse>(`/api/todos/${todo.id}`, {
                is_completed: !todo.is_completed,
            }),
        onSuccess: () => {
            queryClient.invalidateQueries({ queryKey: ['todos'] });
        },
    });

    const deleteTodo = useMutation<ApiResponse<null>, Error, number>({
        mutationFn: (id) => deleteJson<ApiResponse<null>>(`/api/todos/${id}`),
        onSuccess: () => {
            queryClient.invalidateQueries({ queryKey: ['todos'] });
        },
    });

    const todos = data?.data ?? [];

    const stats = useMemo(() => {
        const total = todos.length;
        const completed = todos.filter((todo) => todo.is_completed).length;
        const active = total - completed;

        return { total, completed, active };
    }, [todos]);

    function handleSubmit(event: FormEvent<HTMLFormElement>) {
        event.preventDefault();

        const title = newTitle.trim();

        if (!title) {
            return;
        }

        createTodo.mutate(title);
    }

    return (
        <>
            <Head title={title || 'Todo List'} />

            <main className="min-h-screen bg-slate-950 px-6 py-10 text-white">
                <div className="mx-auto max-w-5xl space-y-8">
                    <section className="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.04] p-8 shadow-2xl shadow-blue-950/40">
                        <div className="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                            <div>
                                <p className="text-sm font-semibold uppercase tracking-[0.25em] text-blue-300">
                                    ISAC-2026 Todo System
                                </p>

                                <h1 className="mt-4 text-4xl font-bold tracking-tight md:text-6xl">
                                    Todo List
                                </h1>

                                <p className="mt-4 max-w-2xl text-base leading-7 text-slate-300">
                                    React TypeScript UI yang connect ke Laravel API, disimpan ke MySQL,
                                    dan dikelola dengan TanStack Query.
                                </p>
                            </div>

                            <div className="grid grid-cols-3 gap-3 rounded-3xl border border-white/10 bg-slate-900/80 p-3">
                                <div className="rounded-2xl bg-white/5 p-4 text-center">
                                    <p className="text-2xl font-bold">{stats.total}</p>
                                    <p className="text-xs text-slate-400">Total</p>
                                </div>

                                <div className="rounded-2xl bg-white/5 p-4 text-center">
                                    <p className="text-2xl font-bold">{stats.active}</p>
                                    <p className="text-xs text-slate-400">Active</p>
                                </div>

                                <div className="rounded-2xl bg-white/5 p-4 text-center">
                                    <p className="text-2xl font-bold">{stats.completed}</p>
                                    <p className="text-xs text-slate-400">Done</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section className="rounded-[2rem] border border-white/10 bg-white/[0.04] p-6 shadow-xl">
                        <form onSubmit={handleSubmit} className="flex flex-col gap-3 md:flex-row">
                            <input
                                type="text"
                                value={newTitle}
                                onChange={(event) => setNewTitle(event.target.value)}
                                placeholder="Tulis todo baru..."
                                className="min-h-12 flex-1 rounded-2xl border border-white/10 bg-slate-900 px-5 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-blue-400"
                            />

                            <button
                                type="submit"
                                disabled={createTodo.isPending || !newTitle.trim()}
                                className="min-h-12 rounded-2xl bg-blue-500 px-6 text-sm font-bold text-white shadow-lg shadow-blue-500/20 transition hover:bg-blue-400 disabled:cursor-not-allowed disabled:opacity-50"
                            >
                                {createTodo.isPending ? 'Menyimpan...' : 'Tambah Todo'}
                            </button>
                        </form>

                        {createTodo.isError && (
                            <p className="mt-3 text-sm text-red-300">
                                Gagal menambah todo: {createTodo.error.message}
                            </p>
                        )}
                    </section>

                    <section className="rounded-[2rem] border border-white/10 bg-white/[0.04] p-6 shadow-xl">
                        <div className="mb-5 flex items-center justify-between gap-3">
                            <div>
                                <h2 className="text-xl font-bold">Daftar Todo</h2>
                                <p className="mt-1 text-sm text-slate-400">
                                    Data diambil dari /api/todos.
                                </p>
                            </div>

                            {isFetching && (
                                <span className="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-300">
                                    Syncing...
                                </span>
                            )}
                        </div>

                        {isLoading && (
                            <div className="rounded-2xl border border-white/10 bg-slate-900 p-5 text-sm text-slate-300">
                                Loading todos...
                            </div>
                        )}

                        {isError && (
                            <div className="rounded-2xl border border-red-400/30 bg-red-500/10 p-5 text-sm text-red-200">
                                Gagal mengambil data: {error.message}
                            </div>
                        )}

                        {!isLoading && !isError && todos.length === 0 && (
                            <div className="rounded-2xl border border-dashed border-white/10 bg-slate-900/70 p-10 text-center">
                                <p className="text-lg font-semibold">Belum ada todo.</p>
                                <p className="mt-2 text-sm text-slate-400">
                                    Tambahkan todo pertama kamu dari form di atas.
                                </p>
                            </div>
                        )}

                        {todos.length > 0 && (
                            <div className="space-y-3">
                                {todos.map((todo) => (
                                    <div
                                        key={todo.id}
                                        className="flex flex-col gap-3 rounded-2xl border border-white/10 bg-slate-900/80 p-4 md:flex-row md:items-center md:justify-between"
                                    >
                                        <button
                                            type="button"
                                            onClick={() => toggleTodo.mutate(todo)}
                                            disabled={toggleTodo.isPending}
                                            className="flex min-w-0 flex-1 items-center gap-3 text-left disabled:cursor-not-allowed disabled:opacity-60"
                                        >
                                            <span
                                                className={[
                                                    'flex h-6 w-6 shrink-0 items-center justify-center rounded-full border text-xs',
                                                    todo.is_completed
                                                        ? 'border-emerald-400 bg-emerald-400 text-slate-950'
                                                        : 'border-slate-500 bg-transparent text-transparent',
                                                ].join(' ')}
                                            >
                                                ✓
                                            </span>

                                            <span
                                                className={[
                                                    'truncate text-sm font-semibold md:text-base',
                                                    todo.is_completed
                                                        ? 'text-slate-500 line-through'
                                                        : 'text-white',
                                                ].join(' ')}
                                            >
                                                {todo.title}
                                            </span>
                                        </button>

                                        <button
                                            type="button"
                                            onClick={() => deleteTodo.mutate(todo.id)}
                                            disabled={deleteTodo.isPending}
                                            className="rounded-xl border border-red-400/30 px-4 py-2 text-sm font-semibold text-red-200 transition hover:bg-red-500/10 disabled:cursor-not-allowed disabled:opacity-60"
                                        >
                                            Hapus
                                        </button>
                                    </div>
                                ))}
                            </div>
                        )}
                    </section>
                </div>
            </main>
        </>
    );
}
</file>

