    Todos/
      Index.tsx
  features/
    auth/
      api/
        authApi.ts
      components/
        AuthShell.tsx
        LoginForm.tsx
        RegisterForm.tsx
      hooks/
        useLogin.ts
        useLogout.ts
        useRegister.ts
      schemas/
        authSchema.ts
      types/
        authTypes.ts
    dashboard/
      api/
        dashboardApi.ts
      components/
        DashboardHero.tsx
        DashboardStats.tsx
        DashboardSummaryCard.tsx
        RecentTodosCard.tsx
        TodoProgressCard.tsx
      hooks/
        useDashboard.ts
      types/
        dashboardTypes.ts
    todos/
      api/
        todoApi.ts
      components/
        TodoCreateForm.tsx
        TodoEmptyState.tsx
        TodoErrorState.tsx
        TodoHero.tsx
        TodoItem.tsx
        TodoList.tsx
        TodoLoadingState.tsx
        TodoStats.tsx
      hooks/
